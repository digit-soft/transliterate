{
  "name": "digit-soft/transliterate",
  "description": "Transliteration package for Laravel",
  "version": "10.0.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Digit",
      "email": "digit.vova@gmail.com",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "DigitSoft\\Transliterate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DigitSoft\\Transliterate\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-intl": "*",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "orchestra/testbench": "^6.0",
    "friendsofphp/php-cs-fixer": "^3.9",
    "brainmaestro/composer-git-hooks": "^2.8"
  },
  "extra": {
    "laravel": {
      "providers": [
        "DigitSoft\\Transliterate\\ServiceProvider"
      ],
      "aliases": {
        "Transliterate": "DigitSoft\\Transliterate\\Facade"
      }
    },
    "hooks": {
      "pre-commit": [
        "php-cs-fixer fix ."
      ]
    }
  },
  "scripts": {
    "test": "phpunit",
    "check-style": "php-cs-fixer fix src/ --dry-run --diff"
  }
}
